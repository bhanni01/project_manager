# PostgreSQL — pooled connection (PgBouncer in production); used for normal queries.
# Local dev uses the Docker Postgres on port 5433 (see docker-compose.yml).
DATABASE_URL="postgresql://pt:pt@localhost:5433/project_tracker?schema=public"

# PostgreSQL — direct connection for Prisma migrations and the FY rollover transaction.
# In local dev the two URLs are identical (no PgBouncer).
DIRECT_URL="postgresql://pt:pt@localhost:5433/project_tracker?schema=public"

# Auth.js v5 — generate with:  openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
